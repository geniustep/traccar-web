# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender in Resend (e.g. after adding domain elmogps.com).
# Example: "ELMOGPS <noreply@elmogps.com>"
RESEND_FROM_EMAIL=

# Inbox for contact form submissions (default in code: contact@elmogps.com)
CONTACT_TO_EMAIL=contact@elmogps.com
